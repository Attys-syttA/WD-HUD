<Window x:Class="WdHud.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WD-HUD"
        Width="168"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False">
    <Window.Resources>
        <Style x:Key="MetricLabelStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#BFD7DEE8" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="Margin" Value="0,1,0,1" />
        </Style>
        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#FFFFFFFF" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Margin" Value="0,1,0,1" />
        </Style>
        <Style x:Key="ChromeButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="20" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#CCFFFFFF" />
            <Setter Property="Background" Value="#1AFFFFFF" />
            <Setter Property="BorderBrush" Value="#33FFFFFF" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Top" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>
    <Border Margin="0"
            Padding="14"
            CornerRadius="14"
            BorderThickness="1"
            BorderBrush="#66FFFFFF"
            Background="#B51A1D24"
            MouseLeftButtonDown="OnHudMouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24"
                              ShadowDepth="0"
                              Opacity="0.42"
                              Color="#000000" />
        </Border.Effect>
        <StackPanel>
            <Grid Margin="0,0,0,8">
                <TextBlock Text="{Binding TimeText}"
                           Visibility="{Binding TimeVisibility}"
                           FontFamily="Segoe UI"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#FFFFFFFF"
                           HorizontalAlignment="Center"
                           Margin="0,0,22,0" />
                <Button Content="_"
                        Click="OnMinimizeToTrayClicked"
                        Style="{StaticResource ChromeButtonStyle}"
                        ToolTip="Minimize to tray" />
            </Grid>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="54" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="22" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="22" />
                    <RowDefinition Height="22" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="CPU" Style="{StaticResource MetricLabelStyle}" />
                <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding CpuUsageText}" Foreground="{Binding CpuUsageBrush}" Style="{StaticResource MetricValueStyle}" />
                <TextBlock Grid.Row="1" Grid.Column="0" Text="RAM" Style="{StaticResource MetricLabelStyle}" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding RamUsageText}" Foreground="{Binding RamUsageBrush}" Style="{StaticResource MetricValueStyle}" />
                <TextBlock Grid.Row="2" Grid.Column="0" Text="GPU" Style="{StaticResource MetricLabelStyle}" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding GpuUsageText}" Foreground="{Binding GpuUsageBrush}" Style="{StaticResource MetricValueStyle}" />
                <TextBlock Grid.Row="3" Grid.Column="0" Text="CPU °C" Style="{StaticResource MetricLabelStyle}" />
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding CpuTempText}" Foreground="{Binding CpuTempBrush}" Style="{StaticResource MetricValueStyle}" />
                <TextBlock Grid.Row="4" Grid.Column="0" Text="GPU °C" Style="{StaticResource MetricLabelStyle}" />
                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding GpuTempText}" Foreground="{Binding GpuTempBrush}" Style="{StaticResource MetricValueStyle}" />
            </Grid>
        </StackPanel>
    </Border>
</Window>
